# EvoClaw 配置文件示例
# 复制为 ~/.evoclaw/config/evoclaw.yaml 并修改

# 进程通信端点
endpoints:
  engine_pub: "ipc:///tmp/evoclaw-engine-pub.sock"
  engine_router: "ipc:///tmp/evoclaw-engine-router.sock"
  compiler_dealer: "ipc:///tmp/evoclaw-compiler-dealer.sock"
  dashboard_sub: "ipc:///tmp/evoclaw-dashboard-sub.sock"

# 日志
logging:
  level: "info"          # trace/debug/info/warn/error/critical
  directory: "~/.evoclaw/logs"

# 数据目录
data:
  root: "~/.evoclaw/data"
  events_dir: "events"
  memory_dir: "memory"

# LLM 配置
llm:
  provider: "openai"
  base_url: "https://api.openai.com/v1"
  model: "gpt-4"
  max_retries: 3
  timeout_seconds: 30
  # API Key 通过环境变量 EVOCLAW_LLM_API_KEY 设置

# Discord Bot
discord:
  # Token 通过环境变量 EVOCLAW_DISCORD_TOKEN 设置
  command_prefix: "/"

# Dashboard
dashboard:
  port: 8080
  host: "127.0.0.1"
