# EvoClaw 配置文件示例
# 复制为 ~/.evoclaw/config/evoclaw.yaml 使用
# 环境变量可覆盖任意配置项：EVOCLAW_ + 大写KEY + 下划线替换点号
#   例：bus.engine_pub → EVOCLAW_BUS_ENGINE_PUB

# ── 进程间通信端点 ──────────────────────────────────────────
bus:
  engine_pub: "ipc:///tmp/evoclaw-engine-pub.sock"
  engine_router: "ipc:///tmp/evoclaw-engine-router.sock"
  compiler_dealer: "ipc:///tmp/evoclaw-compiler-dealer.sock"
  dashboard_sub: "ipc:///tmp/evoclaw-dashboard-sub.sock"

# ── 日志 ────────────────────────────────────────────────────
log:
  level: "info"
  directory: "~/.evoclaw/logs"

# ── 数据目录 ────────────────────────────────────────────────
data:
  root: "~/.evoclaw/data"
  events_dir: "events"
  memory_dir: "memory"

# ── LLM ─────────────────────────────────────────────────────
llm:
  provider: "openai"
  model: "gpt-4o"
  max_retries: 3
  timeout_seconds: 30

# ── Discord Bot ─────────────────────────────────────────────
discord:
  enabled: true

# ── 进化参数 ────────────────────────────────────────────────
evolution:
  pattern_threshold: 3
  cooldown_hours: 24
  sandbox_enabled: true
